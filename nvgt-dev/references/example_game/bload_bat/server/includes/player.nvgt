*/
if(players[i].dead==false)
{
if(players[i].poisoned==true)
{
if(players[i].hurttimer.elapsed>=5000 and players[i].hurt==false)
{
players[i].hurttimer.restart();
players[i].hurtlevel+=random(5,15);
players[i].health-=random(50, 100);
players[i].hitby="the after effects of poison";
players[i].play_hit_sound();
send_reliable(players[i].peer_id,"Poison!",2);
send_reliable(players[i].peer_id,"walkmod",0);
}
if(players[i].hurtlevel>=100 and players[i].hurt==false)
{
players[i].hurt=true;
players[i].sleep("You just can't take the pain anymore! You collapse!");
}
}
if(players[i].sleeping==true)
{
if(players[i].sleeptimer.elapsed>=5000)
{
players[i].sleeptimer.restart();
players[i].health+=random(20, 50);
players[i].sleepinglevel+=random(5, 10);
}
if(players[i].sleepinglevel>=100)
{
players[i].wake((players[i].poisoned==true?"You start feeling better from that mess. You attempt to move, and are surprised you can move with no problem anymore!":""));
if(players[i].poisoned==true) players[i].poisoned=false;
}
}
}
if(players[i].invchecktimer.elapsed>=30000) {
players[i].invchecktimer.restart();
if(serialize(players[i].inv)!=players[i].cachedinv)
{
string data=serialize(players[i].inv);
send_reliable(players[i].peer_id,"invis "+data,0);
players[i].cachedinv=data;
}
}
if(players[i].health<=0 and players[i].dead==false)
{
players[i].health=1000;
players[i].deaths++;
string killer;
if(string_contains(players[i].hitby,"'",1)>-1)
{
string[] s=string_split(players[i].hitby, "'", true);
killer=s[0];
}
else
{
killer=players[i].hitby;
}
players[i].firing=false;
int p=get_player_index_from(killer);
if(p>-1)
{
players[p].kills++;
save_char(p);
}
if(players[i].inv.get_keys().length()>0) {
string cid=randomstring(5);
string[] akeys=players[i].ammo.get_keys();
if(akeys.length()>0) {
for(uint j=0; j<akeys.length(); j+=1) {
int val;
players[i].ammo.get(akeys[j],val);
players[i].inv.set("ammo_"+akeys[j],val);
}
}
new_corpse(players[i].inv,cid);
spawn_bodyfall(players[i].x, players[i].y ,players[i].z, players[i].map,2500);
spawn_timeitem(players[i].x, players[i].y, players[i].z, players[i].map, "corpse_of_"+players[i].name+"_"+cid);
}
players[i].inv.delete_all();
send_reliable(players[i].peer_id,"invis "+serialize(players[i].inv),0);
players[i].ammo.delete_all();
dictionary ammotemp;
ammotemp.set("shotgun",20);
ammotemp.set("tiny_mg",15);
ammotemp.set("pistol",20);
ammotemp.set("machinegun",35);
ammotemp.set("rifle",5);
ammotemp.set("rocket_launcher",10);
players[i].ammo=ammotemp;
players[i].food=1000;
send_reliable(players[i].peer_id,"resetwalktime",0);
save_char(i);
players[i].play_death_sound();
send_reliable(0,"play_s kill.ogg",0);
send_reliable(0,killmsg(players[i].name,players[i].hitby,players[i].zone),2);
send_reliable(players[i].peer_id,"die",0);
players[i].dead=true;
if(players[i].poisoned==true)
{
send_reliable(players[i].peer_id,"sleepstop",0);
send_reliable(players[i].peer_id,"startmoving",0);
send_reliable(players[i].peer_id,"resetwalktime",0);
players[i].hurtlevel=0;
players[i].hurttimer.restart();
players[i].healtimer.restart();
players[i].sleeping=false;
players[i].sleepinglevel=0;
players[i].poisoned=false;
players[i].hurt=false;
}
}
}
}
void spawn_player(int x, int y, int z, string map, string name,int pi)
{
player p1(x,y,z,map,name,pi);
players.insert_last(p1);
send_reliable(0, "online "+x+" "+y+" "+z+" "+name+" "+map, 0);
}
string[] nearest_player_sorted_array(player@ p)
{
pld@[] t;
for(uint i=0; i<players.length(); i++)
{
if(players[i].name==p.name||players[i].dead||p.map!=players[i].map) continue;
pld temp(p,players[i]);
t.insert_last(temp);
}
string[] blankret;
if(t.is_empty()) return blankret;
t.sort_descending();
string[] names;
for(uint i=0; i<t.length(); i++)
{
names.insert_last(players[t[i].index].name);
}
return names;
}

class pld
{
double tx,ty,tz;
double sx,sy,sz;
double dist;
int index;
pld(player@ p1, player@ p2)
{
sx=p1.x;sy=p1.y;sz=p1.z;
tx=p2.x;ty=p2.y;tz=p2.z;
index=get_player_index_from(p2.name);
dist=get_3d_distance(sx,sy,sz,tx,ty,tz);
}
int opCmp(pld@ o)
{
if(o.dist<dist) return -1;
if(o.dist>dist) return 1;
return 0;
}
}

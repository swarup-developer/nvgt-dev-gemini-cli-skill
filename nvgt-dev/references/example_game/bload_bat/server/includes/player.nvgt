player(int px, int py, int pz, string pmap, string pname, int ppeer_id)
{
map=pmap;
x=px;
y=py;
z=pz;
name=pname;
peer_id=ppeer_id;
}
bool is_builder()
{
if(this.builder or this.admin or this.dev)
{
return true;
}
return false;
}
bool is_admin()
{
if(this.admin or this.dev)
{
return true;
}
return false;
}
bool is_teammember(string n)
{
if(is_in_team(name)>-1 and n==teamname) return true;
return false;
}
void build_locker() {
if(get_locker_at(this.x, this.y, this.z, this.map)>-1 or this.map!="main" or this.gettile()=="" or string_left(this.gettile(),4)=="wall") {
this.packet("Sorry, you can't build a locker here",0);
return;
}
if(has_locker(this.name)>-1) {
this.packet("You already have a locker!",0);
return;
}
if(is_in_team(this.name)<0) {
this.packet("You must be in a team to build lockers!",0);
return;
}
if(this.inv_item_amount("metal")<250) {
this.packet("You don't have enough metal to build a locker. You need at least 250 pieces of metal to build something",0);
return;
}
this.stun(this.lockerplacetime);
this.lockerplacetimer.restart();
this.lockerplacing=true;
this.playsound("locker_placing");
}
void chat(string message)
{
for(uint i=0; i<players.length(); i++)
{
send_reliable(players[i].peer_id,"chat "+message,1);
}
}
void playsound(string sound, bool include_me=true,bool SendReliable=true)
{
if(include_me) {
if(SendReliable==true) send_reliable(peer_id,"play_s "+sound+".ogg",0);
else if(SendReliable==false) send_unreliable(peer_id,"play_s "+sound+".ogg",0);
}
send_plus(peer_id, sound+" "+x+" "+y+" "+z+" "+map, 3,false);
}
string gettile() {
return get_tile_at(x, y, z, map);
}
void stun(const int ms) {
this.stuntime=ms;
this.packet("stopmoving",0);
this.stuntimer.restart();
this.stunned=true;
}
void packet(const string pkt,const int chan=2,const bool r=true) {
if(r)
send_reliable(this.peer_id,pkt,chan);
else
send_unreliable(this.peer_id,pkt,chan);
}
void get_weapon_properties(const string w) {
if(wdata.exists(w)==false) return;
else {
string holder;
wdata.get(w,holder);
string[] stuff=string_split(holder," ",false);
int time=stn(stuff[0]);
string state=holder[1];
if(state!="normal" or state!="norm") {
this.weaponauto=true;
}
this.firetime=time;
}
}
void eat(const string f) {
int plus;
fooditems.get(f,plus);
this.food+=plus;
play("eat"+f,this.x,this.y,this.z,this.map);
}
void play_hit_sound()
{
play("guy"+this.guy+"hit"+random(1,3),this.x,this.y,this.z,this.map,this);
}
void wake(string msg="") {
send_reliable(this.peer_id,"resetwalktime",0);
send_reliable(this.peer_id,"startmoving",0);
send_reliable(this.peer_id,"sleepstop",0);
this.sleeping=false;
this.sleepinglevel=0;
if(msg!="") send_reliable(this.peer_id,msg,2);
}
void sleep(string msg="") {
send_reliable(this.peer_id,"stopmoving",0);
send_reliable(this.peer_id,"sleepstart",0);
if(msg!="")
send_reliable(this.peer_id,msg,2);
this.sleeping=true;
spawn_bodyfall(this.x,this.y,this.z,this.map,40);
this.sleeptimer.restart();
}
void play_death_sound()
{
play("guy"+this.guy+"death",this.x,this.y,this.z,this.map);
}
dictionary ammo;
int ammocheck(string item)
{
if(!this.ammo.exists(item))
{
return 0;
}
int ret;
this.ammo.get(item,ret);
if(ret<0)
{
this.ammo.delete(item);
return 0;
}
return ret;
}
void ammogive(string item, int amount)
{
int a;
if(!this.ammo.exists(item))
{
this.ammo.set(item,amount);
}
else
{
this.ammo.get(item,a);
if (a+amount<=0)
this.ammo.delete(item);
else
{
this.ammo.set(item,a+amount);
}
}
}
int inv_item_amount(string item)
{
if(!this.inv.exists(item))
{
return 0;
}
int ret;
this.inv.get(item,ret);
if(ret<0)
{
this.inv.delete(item);
return 0;
}
return ret;
}
void give(string item, int amount)
{
int a;
if(!this.inv.exists(item))
{
this.inv.set(item,amount);
}
else
{
this.inv.get(item,a);
if (a+amount<=0)
this.inv.delete(item);
else
{
this.inv.set(item,a+amount);
}
string data=serialize(this.inv);
this.cachedinv=data;
send_reliable(this.peer_id,"invis "+data,0);
send_reliable(this.peer_id,"invis "+data,0);
send_reliable(this.peer_id,"invis "+data,0);
}
}
}
void playerloop()
{
for(uint i=0; i<players.length(); i++)
{
if(players[i].lockerplacing==true and players[i].lockerplacetimer.elapsed>=players[i].lockerplacetime) {
players[i].lockerplacing=false;
string newid=randomstring(6);
int newcode=stn(randomstring(4, 2));
create_new_locker(players[i].x, players[i].y, players[i].z, players[i].map, players[i].name, newcode, newid);
players[i].packet("Your locker has been created. Your access code is "+newcode+". It is also strongly recommended that if anything happens, note down your locker ID. It is "+newid);
}
if(players[i].health>5000) players[i].health=5000;
if(players[i].map=="safezone") {
if(players[i].x>20 or players[i].y>20) {
move_player(i,0, 0, 0,players[i].map);
}
}
if(players[i].current_health!=players[i].health) {
players[i].hittimer.restart();
players[i].current_health=players[i].health;
}
if(players[i].firetimer.elapsed>=players[i].firetime and players[i].firing==true and players[i].weapon!="")
{
if(guns.find(players[i].weapon)>-1 and players[i].ammocheck(players[i].weapon)<=0) {
players[i].firing=false;
}
players[i].firetimer.restart();
players[i].playsound(players[i].weapon);
send_reliable_x(0,"distsound "+players[i].weapon+"dist "+players[i].x+" "+players[i].y+" "+players[i].z+" "+players[i].map,0,players[i].x,players[i].y,players[i].z);
spawn_weapon(players[i].x, players[i].y, players[i].z, players[i].facing, players[i].weapon, players[i].map, players[i]);
players[i].ammogive(players[i].weapon,-1);
}
if(players[i].stunned==true and players[i].stuntimer.elapsed>=players[i].stuntime) {
players[i].stunned=false;
players[i].packet("startmoving",0);
}

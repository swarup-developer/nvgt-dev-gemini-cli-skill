timebomb@[] timebombs(0);
class timebomb
{
string owner;
int z;
string map;
int range=30;
int x, y;
int seconds=40000;
int beeptime;
timer beeptimer, bombtimer;
int fire=random(1,3);
timebomb(int tx,int ty,int tz, string tmap, string towner)
{
owner=towner;
x=tx;
y=ty;
z=tz;
map=tmap;
play("timebombdrop",x,y,z,map);
}
}
void timebombloop()
{
for (uint i=0; i<timebombs.length(); i++)
{
timebombs[i].seconds=5000-timebombs[i].bombtimer.elapsed;
timebombs[i].beeptime=timebombs[i].seconds/5+50;
if (timebombs[i].beeptimer.elapsed>=timebombs[i].beeptime)
{
timebombs[i].beeptimer.restart();
play("timebombbeep",timebombs[i].x,timebombs[i].y,timebombs[i].z,timebombs[i].map);
}
if (timebombs[i].seconds<=0)
{
play("timebombexplode",timebombs[i].x,timebombs[i].y,timebombs[i].z,timebombs[i].map);
send_reliable(0,"distsound timebombexplodedist "+timebombs[i].x+" "+timebombs[i].y+" "+timebombs[i].z+" "+timebombs[i].map,0);
if(timebombs[i].fire==1)
spawn_fire(timebombs[i].x,timebombs[i].y,timebombs[i].z,timebombs[i].map,random(50, 150));
for (uint i2=0; i2<players.length(); i2++)
{
if(players[i2].dead or players[i2].invinsible or players[i2].safe) continue;
if (get_3d_distance(timebombs[i].x,timebombs[i].y,timebombs[i].z,players[i2].x,players[i2].y,players[i2].z)<=timebombs[i].range and players[i2].map==timebombs[i].map)
{
players[i2].health-=random(250,400);
players[i2].hitby=timebombs[i].owner+"'s Timebomb";
players[i2].play_hit_sound();
}
}
for (uint i3=0; i3<objs.length(); i3++)
{
if (get_3d_distance(timebombs[i].x,timebombs[i].y,timebombs[i].z,objs[i3].x,objs[i3].y,objs[i3].z)<=timebombs[i].range and objs[i3].map==timebombs[i].map)
{
send_reliable(0,"remitem "+objs[i3].id, 0);
play("itembreak"+random(1,3),objs[i3].x,objs[i3].y,objs[i3].z,objs[i3].map);
objs.remove_at(i3);
}
}
timebombs.remove_at(i);
continue;
}
}
}
void placetimebomb(int x,int y, int z, string map,string owner)
{
timebomb bomb1(x,y,z,map,owner);
timebombs.insert_last(bomb1);
}
void destroy_all_timebombs()
{
timebombs.resize(0);
}
#include"includes/bgt_compat.nvgt"
#include"includes/dll_terlark.nvgt"
terlark tl;
void main()
{
if(file_exists("bbserverB.exe")==false)
{
tl.dlg_error("Error!","server file is missing. compile the server and rerun this script", false);
exit();
}
update();
}
void update()
{
bool connect=tl.ftp_connect("lkd-audio.ddns.net","charlie","pwsvrpw123");
if(!connect)
{
tl.dlg_error("Error!","Could not connect to FTP server.",false);
exit();
}
else
{
bool j=tl.ftp_upload("bbserverB.exe","BloodbathServer/b/bbserverB1.exe",true);
if(!j)
{
tl.dlg_error("Error!","Could not upload server file.", false);
exit();
}
else
{
file_delete("bbserver.exe");
}
file u;
u.open("updating.txt","wb");
u.close();
j=tl.ftp_upload("updating.txt","BloodbathServer/b/update.txt",true);
if(j)
{
file_delete("updating.txt");
}
}
}

class virtualizer
{
int charrepeat=1;
int capmode=1;
string input(string text, bool online=false, bool secure=false)
{
int cursor;
string message;
speak(text);
cursor=0;
string[] ms;
get_characters();
while(true)
{
wait(5);
if(spd.is_hacking(200))
{
kill_speedhacker();
}
if(online)
mainloop();
string char=string_left(get_characters(), 1);
if(key_pressed(KEY_TAB))
{
speak(text);
}
if(key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT))
{
if(key_pressed(KEY_BACK))
{
for(uint i=0; i<ms.length(); i++)
{
ms.remove_at(i);
}
ms.resize(0);
cursor=0;
speak("Text cleared");
}
}
if (key_down(KEY_LCONTROL) or key_down(KEY_RCONTROL))
{
if (key_pressed(KEY_V))
{
if(secure)
{
speak("You may not paste text into secure input boxes!");
}
else
{
speak("text pasted");
string cl=clipboard_read_text();
for (uint i=0; i<cl.length(); i++)
{
ms.insert_at(cursor,cl[i]);
cursor+=1;
}
}
}
if (key_pressed(KEY_C))
{
if(secure)
{
speak("You may not copy text from secure input boxes!");
}
else
{
string a;
for (uint i=0; i<ms.length(); i++)
{
a+=ms[i];
}
speak("text copied");
clipboard_copy_text(a);
}
}
}
if (key_pressed(KEY_F2)) {
if (capmode==0) {
capmode=1;
speak("Beep for capital letters");
}
else if (capmode==1) {
capmode=2;
speak("Say “cap” in front of the capital letters");
}
else {
capmode=0;
speak("Treat capital letters no different.");
}
}
if (key_pressed(KEY_F1))
{
if (charrepeat==1)
{
speak("character repeat off");
charrepeat=0;
}
else
{
speak("character repeat on");
charrepeat=1;
}
}
if(char!="")
{
if (charrepeat==1)
{
if (string_is_upper_case(char)) {
if (capmode==1) {
capbeep.stop(); capbeep.play();
speak(secure==true?"*":char);
}
else if (capmode==2)
speak("Cap "+secure==true?"*":char);
else
speak(secure==true?"*":char);
}
else if(string_contains(char, " ", 1)>-1)
{
speak(secure==true?"*":"Space");
}
else
{
speak(secure==true?"*":char);
}
}
if(char==" ")
{
}
else if(string_is_upper_case(char))
{
}
else
{
}
ms.insert_at(cursor,char);
cursor+=1;
}
if(key_pressed(KEY_BACK) and ms.length() > 0 and cursor>=1)
{
if(online)
send_reliable(0,"playsnd keytype_delete.ogg",0);
else
p.play_stationary("keytype_delete.ogg",false);
string char=ms[cursor-1];
if (char==" ")
speak(secure==true?"*":"space");
else {
if (string_is_upper_case(char)) {
if (capmode==1) {
capbeep.stop(); capbeep.play();
speak(secure==true?"*":char);
}
else if (capmode==2)
speak("Cap "+secure==true?"*":char);
else
speak(secure==true?"*":char);
}
else
speak(secure==true?"*":char);
}
ms.remove_at(cursor-1);
cursor-=1;
}
if(key_pressed(KEY_DELETE) and ms.length() > 0 and cursor>0 and cursor<ms.length())
{
if(online)
send_reliable(0,"playsnd keytype_delete.ogg",0);
else
p.play_stationary("keytype_delete.ogg",false);
string char=ms[cursor+1];
if (char==" ")
speak(secure==true?"*":"space");
else {
if (string_is_upper_case(char)) {
if (capmode==1) {
capbeep.stop(); capbeep.play();
speak(secure==true?"*":char);
}
else if (capmode==2)
speak("Cap "+secure==true?"*":char);
else
speak(secure==true?"*":char);
}
else
speak(secure==true?"*":char);
}
ms.remove_at(cursor+1);
}
if(key_pressed(KEY_DOWN) or key_pressed(KEY_UP))
{
if(secure==true)
{
speak(ms.length()+" *");
}
else
{
string a;
for (uint i=0; i<ms.length(); i++)
{
a+=ms[i];
}
speak(a);
}
}
if(key_pressed(KEY_LEFT) and cursor>0)
{
if(ms.length()>0)
{
cursor-=1;
if (cursor>=ms.length())
{
speak("Blank");
}
else if (ms[cursor]==" ")
speak(secure==true?"*":"space");
else
{
if (string_is_upper_case(ms[cursor])) {
if (capmode==1) {
capbeep.stop(); capbeep.play();
speak(secure==true?"*":ms[cursor]);
}
else if (capmode==2)
speak("Cap "+secure==true?"*":ms[cursor]);
else
speak(secure==true?"*":ms[cursor]);
}
else
speak(secure==true?"*":ms[cursor]);
}
}
else
speak("blank");
}
if(key_pressed(KEY_RIGHT) and cursor<ms.length())
{
if(ms.length() > 0)
{
cursor+=1;
if (cursor>=ms.length())
speak("Blank");
else if (ms[cursor]==" ")
speak(secure==true?"*":"space");
else
{
if (string_is_upper_case(ms[cursor])) {
if (capmode==1) {
capbeep.stop(); capbeep.play();
speak(secure==true?"*":ms[cursor]);
}
else if (capmode==2)
speak("Cap "+secure==true?"*":ms[cursor]);
else
speak(secure==true?"*":ms[cursor]);
}
else
speak(secure==true?"*":ms[cursor]);
}
}
else
speak("blank");
}
if(key_pressed(KEY_HOME))
{
if(ms.length() > 0)
{
cursor=0;
if (cursor>=ms.length())
speak("Blank");
else if (ms[cursor]==" ")
speak(secure==true?"*":"space");
else
{
if (string_is_upper_case(ms[cursor])) {
if (capmode==1) {
capbeep.stop(); capbeep.play();
speak(secure==true?"*":ms[cursor]);
}
else if (capmode==2)
speak("Cap "+secure==true?"*":ms[cursor]);
else
speak(secure==true?"*":ms[cursor]);
}
else
speak(secure==true?"*":ms[cursor]);
}
}
else
speak("blank");
}
if(key_pressed(KEY_END))
{
if(ms.length() > 0)
{
cursor=ms.length();
if (cursor>=ms.length())
speak("Blank");
else if (ms[cursor]==" ")
speak(secure==true?"*":"space");
else
{
if (string_is_upper_case(ms[cursor])) {
if (capmode==1) {
capbeep.stop(); capbeep.play();
speak(secure==true?"*":ms[cursor]);
}
else if (capmode==2)
speak("Cap "+secure==true?"*":ms[cursor]);
else
speak(secure==true?"*":ms[cursor]);
}
else
speak(secure==true?"*":ms[cursor]);
}
}
else
speak("blank");
}
if(key_pressed(KEY_ESCAPE))
{
speak("Cancel.");
return "";
}
else if(key_pressed(KEY_RETURN))
{
if(online)
send_reliable(0,"playsnd keytype_return.ogg",0);
else
p.play_stationary("keytype_return.ogg",false);
if (ms.length() > 0)
{
for (uint i=0; i<ms.length(); i++)
{
message+=ms[i];
}
return message;
}
else if (ms.length()==0)
{
speak("Cancel.");
return "";
}
}
}
return "";
}
}

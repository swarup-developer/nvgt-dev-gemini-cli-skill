if(keylist[i] == KEY_0)
weapon_index = 9;
else
weapon_index = keylist[i] - KEY_1;
if(weapon_index >= 0 and weapon_index < weapons.length() and w != weapon_index)
{
w = weapon_index;
speak(weapons[w]);
send_reliable(0, "draw " + weapons[w], 0);
}
}
}

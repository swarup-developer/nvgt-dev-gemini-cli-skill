movetimer.restart();
move(Forward);
}
else if(key_down(KEY_DOWN))
{
movetimer.restart();
move(Backward);
}
else if(key_down(KEY_LEFT))
{
movetimer.restart();
move(Left);
}
else if(key_down(KEY_RIGHT))
{
movetimer.restart();
move(Right);
}
}
keylist=keys_pressed();
for(uint i = 0; i < keylist.length(); i++)
{
if(keylist[i] >= KEY_1 and keylist[i] <= KEY_0 and weapons.length() > 0)
{

void positions()
{
distpool.update_listener_3d(me.x, me.y, me.z, facing);
p.update_listener_3d(me.x, me.y, me.z, facing);
itempool.update_listener_3d(me.x, me.y, me.z, facing);
mpool.update_listener_3d(me.x, me.y, me.z, facing);
}
void checkloc()
{
if(get_zone_at(me.x, me.y, me.z)!="")
{
string zone=get_zone_at(me.x, me.y, me.z);
if(currentloc!=zone)
{
currentloc=zone;
speak(currentloc);
send_reliable(0,"update_zone "+currentloc,0);
}
}
else if(get_zone_at(me.x, me.y, me.z)=="" and currentloc!="")
{
speak("Uncharted area");
currentloc="";
}
}
void fade_pool_out(sound_pool@ pool, bool destroy=true)
{
int volume=0;
while(volume>-20)
{
volume--;
for (uint i=0; i<pool.items.length(); i++)
{
if (@pool.items[i].handle!=null)
pool.items[i].handle.volume=volume;
}
wait(20);
}
if(destroy)
pool.destroy_all();
}
void fade_pool_in(sound_pool@ pool)
{
int volume=-20;
while(volume<0)
{
volume++;
for (uint i=0; i<pool.items.length(); i++)
{
if (@pool.items[i].handle!=null)
pool.items[i].handle.volume=volume;
}
wait(20);
}
}
string get_script_path()
{
string scriptpath;
if(SCRIPT_COMPILED==false)
{
scriptpath=SCRIPT_CURRENT_FILE;
}
else
{
scriptpath=SCRIPT_EXECUTABLE;
}
return scriptpath;
}
void kill_speedhacker()
{
if(connected)
send_reliable(0,"cheater",0);
sound sph;
sph.load("sph.ogg");
sph.play_wait();
sph.close();
alert("Error","No speedhacking allowed. If you are not speedhacking and get this error, please contact the developers.");
exit();
}

string read_from_file_in_pack(string filename)
{
file f;
if(packfile.file_exists(filename)==false) return "File not found";
packfile.extract_file(filename,DIRECTORY_TEMP+"\\"+filename);
file_decrypt(DIRECTORY_TEMP+"\\"+filename,DIRECTORY_TEMP+"\\dec_"+filename,"hackmybloodysoundsifyoudare145nuke");
f.open(DIRECTORY_TEMP+"\\dec_"+filename,"rb");
string ret=f.read();
f.close();
file_delete(DIRECTORY_TEMP+"\\"+filename);
file_delete(DIRECTORY_TEMP+"\\dec_"+filename);
return ret;
}
void serverbox(int mode=0, int maxlength=-1, int autosend=0, int keypresses=-1, string sendtext="server_box", string text="enter text")
{
string message;
speak(text);
get_characters();
int total_keypresses=0;
while(true)
{
wait(5);
if(spd.is_hacking(200)==true)
kill_speedhacker();
fallloop();
netloop();
p.update_listener_3d(me.x, me.y,me.z,facing);
mpool.update_listener_3d(me.x, me.y, me.z, facing);
string char=get_characters();
distpool.update_listener_3d(me.x, me.y, me.z, facing);
if (key_pressed(KEY_F2))
{
if (v.charrepeat==1)
{
speak("character repeat off");
v.charrepeat=0;
}
else
{
speak("character repeat on");
v.charrepeat=1;
}
}
if(mode==1)
{
if(!string_is_alphanumeric(char) and char!=" ") char="";
}
if(mode==2)
{
if(!string_is_digits(char)) char="";
}
if(char!="")
{
total_keypresses+=char.length();
if (v.charrepeat==1)
{
speak(char);
}
message+=char;
if(total_keypresses>=keypresses and keypresses>-1)
{
if(autosend>=1)
{
message=string_replace(message, " ", "[SPCE]", true);
send_reliable(0, sendtext+" "+message, 0);
get_characters();
keys_released();
keys_pressed();
serverboxcooldowntimer.restart();
return;
}
}
}
if(key_pressed(KEY_BACK))
{
if(message.length()>0)
{
string char=message[message.length()-1];
speak(char);
message.resize(message.length()-1);
}
total_keypresses++;
if(total_keypresses>=keypresses and keypresses>-1)
{
if(autosend>=1)
{
if(message.length()<=0)
message="[bckspace]";
send_reliable(0, sendtext+" "+message, 0);
get_characters();
keys_released();
keys_pressed();
serverboxcooldowntimer.restart();
return;
}
}
}
if(key_pressed(KEY_LEFT) or key_pressed(KEY_RIGHT) or key_pressed(KEY_UP) or key_pressed(KEY_DOWN))
{
if(message.length() > 0)
speak(message);
else
speak("blank");
}
if(key_pressed(KEY_ESCAPE))
{
send_reliable(0, sendtext+" [cncel]", 0);
get_characters();
keys_released();
keys_pressed();
serverboxcooldowntimer.restart();
return;
}
else if(key_pressed(KEY_RETURN) and message.length() > 0)
{
send_reliable(1, sendtext+" "+message, 0);
get_characters();
keys_released();
keys_pressed();
return;
}
wait(5);
}
get_characters();
get_characters();
keys_released();
keys_pressed();
}
void doorcheck()
{
for (uint i=0; i<doors.length(); i++)
{
if (me.x==doors[i].dx and me.y==doors[i].dy and me.z==doors[i].dz and dmoving==false)
{
can_move=false;
p.play_stationary(doors[i].ds3, false);
send_reliable(0,"xplay "+doors[i].ds3,0);
doors[i].doorsound2=p.play_stationary(doors[i].ds2, true);
doors[i].moving=true;
dmoving=true;
send_reliable(0,"iamdmoving "+doors[i].ds2,0);
return;
}
else if (i>=doors.length()-1)
{
}
}
}
